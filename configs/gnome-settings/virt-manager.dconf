[virt-manager]
manager-window-height=1100
manager-window-width=1700
xmleditor-enabled=true

[virt-manager/connections]
autoconnect=['qemu:///system']
uris=['qemu:///system']

[virt-manager/new-vm]
firmware='uefi'
graphics-type='system'

[virt-manager/stats]
enable-memory-poll=true

[virt-manager/vmlist-fields]
disk-usage=false
host-cpu-usage=true
memory-usage=true
network-traffic=false
