{
	"main function": {
		"prefix": "main",
		"body": [
			"int main(int argc, char const *argv[]) {",
			"\t${0:/* code */}",
			"\treturn 0;",
			"}"
		],
		"description": "main function"
	},

	"if statement": {
		"prefix": "if",
		"body": [
			"if (${1:condition}) {",
			"\t${0:/* code */}",
			"}"
		],
		"description": "if statement"
	},

	"if else statement": {
		"prefix": "ifel",
		"body": [
			"if (${1:condition}) {",
			"\t${2:/* code */}",
			"} else {",
			"\t${3:/* code */}",
			"}"
		],
		"description": "if else statement"
	},

	"if else if statement": {
		"prefix": "ifelif",
		"body": [
			"if (${1:condition}) {",
			"\t${2:/* code */}",
			"} else if (${3:condition}) {",
			"\t$4:/* code */}",
			"} else {",
			"\t${5:/* code */}",
			"}"
		],
		"description": "if else statement"
	},

	"else if statement": {
		"prefix": "elif",
		"body": [
			" else if (${1:condition}) {",
			"\t${0:/* code */}",
			"}"
		],
		"description": "else if statement"
	},

	"else statement": {
		"prefix": "else",
		"body": [
			" else {",
			"\t${0:/* code */}",
			"}"
		],
		"description": "else statement"
	},

	"switch statement": {
		"prefix": "switch",
		"body": [
			"switch (${1:expression}) {",
			"case ${2:constant expression}:",
			"\t${3:/* code */}",
			"\tbreak;",
			"default:",
			"\tbreak;",
			"}"
		],
		"description": "switch statement"
	},

	"for loop": {
		"prefix": "for",
		"body": [
			"for (${1:size_t} ${2:i} = 0; ${2:i} < ${3:count}; ${2:i}${4:++}) {",
			"\t${0:/* code */}",
			"}"
		],
		"description": "for loop"
	},

	"while loop": {
		"prefix": "while",
		"body": [
			"while (${1:condition}) {",
			"\t${0:/* code */}",
			"}"
		],
		"description": "while loop"
	},

	"do while loop": {
		"prefix": "do",
		"body": [
			"do {",
			"\t${0:/* code */}",
			"} while (${1:condition});"
		],
		"description": "do while loop"
	}
}